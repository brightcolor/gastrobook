##############################################################################
#  SWAYY – Konfigurationsdatei
#  Kopieren als .env und alle Pflichtfelder ausfüllen.
#  Geheime Werte (APP_KEY, Passwörter, API-Keys) NIEMALS ins Git einchecken!
##############################################################################


# ===========================================================================
# APP – Grundeinstellungen
# ===========================================================================

# Anzeigename der Applikation (erscheint in E-Mail-Betreffzeilen, Logs, etc.)
APP_NAME=Swayy

# Umgebung: "production" auf dem Live-Server, "local" für lokale Entwicklung.
# Im production-Modus werden keine Stack-Traces an Nutzer ausgegeben.
APP_ENV=production

# Kryptografischer Schlüssel der App – wird für Verschlüsselung und Signaturen
# aller Sessions, Cookies und verschlüsselten Felder genutzt.
# GENERIEREN: php artisan key:generate (oder: php artisan key:generate --show)
# WICHTIG: Einmal gesetzt niemals ändern – bestehende Sessions/Daten werden
# damit signiert. Leer = App startet nicht.
APP_KEY=

# Debug-Ausgaben: Nur "true" für lokale Entwicklung. Auf dem Live-Server IMMER
# false – sonst werden Stack-Traces mit Datenbankstruktur und .env-Inhalten
# öffentlich ausgegeben!
APP_DEBUG=false

# Öffentliche URL der App (mit Schema, ohne Trailing-Slash).
# Wird für Links in E-Mails, Asset-Pfade und Weiterleitungen genutzt.
# Beispiele: https://app.meindomain.de | http://localhost:8080
APP_URL=http://localhost


# ===========================================================================
# SPRACHE & LOKALISIERUNG
# ===========================================================================

# Standardsprache der Applikation (Blade-Übersetzungen, Datumsformat).
APP_LOCALE=de

# Fallback-Sprache, wenn eine Übersetzung in APP_LOCALE fehlt.
APP_FALLBACK_LOCALE=en

# Faker-Locale für Testdaten (Seeder). Hat keinen Einfluss auf Produktion.
APP_FAKER_LOCALE=de_DE


# ===========================================================================
# WARTUNGSMODUS
# ===========================================================================

# Treiber für den Wartungsmodus (php artisan down / up).
# "file" = Standard, funktioniert immer.
# "cache" = empfohlen bei mehreren PHP-Workern (z. B. hinter einem Load Balancer),
#            damit alle Worker gleichzeitig den Wartungsmodus aktivieren.
APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database


# ===========================================================================
# SWAYY – PLATTFORM-EINSTELLUNGEN
# ===========================================================================

# --- Erster Oberadmin (Bootstrap) ---
# Wird beim ersten Start automatisch angelegt, wenn noch kein Admin existiert.
# Swayy führt beim Start "php artisan swayy:create-admin --if-missing" aus.
# Leer lassen, um den Admin manuell per Artisan anzulegen:
#   php artisan swayy:create-admin
# Nach dem ersten Login Passwort im Admin-Backend ändern!
SWAYY_ADMIN_EMAIL=
SWAYY_ADMIN_PASSWORD=
SWAYY_ADMIN_NAME="Administrator"

# Wohin Trial-Warnungen und Billing-Anfragen gesendet werden (SaaS-Owner)
SWAYY_OWNER_EMAIL=info@swayy.de

# --- Live-Board (Echtzeit-Updates) ---
# Das Live-Board (Tischübersicht) erhält Echtzeit-Benachrichtigungen über
# Server-Sent Events (SSE). Jede offene SSE-Verbindung belegt einen PHP-Worker.
#
# true  = SSE aktiviert (empfohlen in Produktion mit php-fpm + mehreren Workern)
# false = Board nutzt Polling alle 10 s (für "php artisan serve" nötig, da dort
#         nur ein Worker läuft und eine SSE-Verbindung den Server blockiert)
#
# Standard: true
SWAYY_BOARD_SSE=true

# --- Stammgast-Erkennung ---
# Ab wie vielen abgeschlossenen Besuchen gilt ein Gast automatisch als Stammgast.
# Zählt zuzüglich zum manuellen VIP-Flag. Standard: 5
SWAYY_REGULAR_AFTER_VISITS=5

# --- Support-E-Mail ---
# Wird in Fehlermeldungen und System-Mails als Kontaktadresse genutzt.
# Optional; ohne Eintrag erscheint kein Support-Link.
SUPPORT_EMAIL=


# ===========================================================================
# SWAYY – SELF-HOSTED LIZENZ
# (Nur relevant, wenn Swayy selbst gehostet wird – swayy.de-Betrieb: auslassen)
# ===========================================================================

# Self-Hosted-Modus aktivieren.
# true  = Lizenzprüfung aktiv; ohne gültige Lizenz werden Admin-Seiten gesperrt
#         (HTTP 402). Öffentliche Buchungsseiten bleiben immer erreichbar.
# false = Kein Lizenzcheck (Standard, für hosted SaaS auf swayy.de).
# SWAYY_SELF_HOSTED=true

# Pfad zur Lizenzdatei (JSON mit Ed25519-Signatur).
# Relativ zu storage/ oder als absoluter Pfad.
# Datei erhältst du nach dem Kauf unter license.swayy.de.
# Standard: license.json (= storage/license.json)
# SWAYY_LICENSE_FILE=license.json

# URL des Widerrufungs-Endpunkts. Normalerweise nicht ändern.
# Standard: https://license.swayy.de/v1/revoked
# SWAYY_REVOCATION_URL=https://license.swayy.de/v1/revoked

# Cache-Dauer des Revocation-Checks in Sekunden. Standard: 604800 (= 7 Tage).
# Netzwerkfehler beim Check sperren die Lizenz NICHT – du hast also immer
# mindestens 7 Tage Offline-Betrieb ohne Unterbrechung.
# SWAYY_LICENSE_REVOCATION_TTL=604800

# Kulanzfrist in Tagen nach Ablauf der Lizenz, bevor der Admin gesperrt wird.
# Innerhalb dieser Frist erscheint ein roter Banner, aber der Betrieb läuft weiter.
# Standard: 14
# SWAYY_LICENSE_GRACE_DAYS=14

# Warnbanner im Admin: wie viele Tage vor Ablauf soll der gelbe Banner erscheinen?
# Standard: 30
# SWAYY_LICENSE_WARN_DAYS=30


# ===========================================================================
# DATENBANK
# ===========================================================================

# Treiber: "pgsql" (empfohlen, wird im Docker-Setup genutzt) oder "sqlite" (nur
# für lokale Tests ohne Datenbankserver sinnvoll).
DB_CONNECTION=pgsql

# Hostname oder IP des Datenbankservers.
# Docker: "db" (Service-Name aus docker-compose.yml). Lokal: "127.0.0.1".
DB_HOST=127.0.0.1

# Port: PostgreSQL Standard = 5432, MySQL = 3306.
DB_PORT=5432

# Name der Datenbank. Muss vorher existieren (wird vom PostgreSQL-Image beim
# ersten Start automatisch angelegt, wenn DB_HOST=db im Docker-Setup).
DB_DATABASE=swayy

# Datenbankbenutzer mit vollen Rechten auf DB_DATABASE.
DB_USERNAME=swayy

# Passwort des Datenbankbenutzers. Sicher und lang wählen!
DB_PASSWORD=


# ===========================================================================
# SESSION
# ===========================================================================

# Wo Sessions gespeichert werden.
# "redis"    = empfohlen in Produktion (schnell, skalierbar, kein DB-Lock)
# "database" = Fallback ohne Redis
# "cookie"   = nur für Einzelserver, unsicher für größere Deployments
SESSION_DRIVER=redis

# Session-Lebensdauer in Minuten (Inaktivitäts-Timeout).
# 120 = 2 Stunden. Für Admin-Zugänge eher kürzer (z. B. 60).
SESSION_LIFETIME=120

# Session-Payload serverseitig verschlüsseln (empfohlen für sensible Daten).
# Nutzt APP_KEY. Leichter Performance-Overhead, kaum spürbar.
# true empfohlen in Produktion.
SESSION_ENCRYPT=false

# Cookie-Pfad (Standard / = global). Nur ändern bei Subpfad-Deployment.
SESSION_PATH=/

# Domain für den Session-Cookie. Leer = automatisch aus APP_URL.
# Für Subdomains mit Punkt-Prefix: ".meindomain.de" (alle Subdomains).
SESSION_DOMAIN=null


# ===========================================================================
# CACHE
# ===========================================================================

# Cache-Backend.
# "redis"    = empfohlen in Produktion (schnell, persistent über Neustarts)
# "database" = Fallback ohne Redis
# "array"    = nur für Tests / lokale Entwicklung (kein persistenter Cache)
CACHE_STORE=redis

# Optionales Prefix für alle Cache-Schlüssel (nützlich bei geteiltem Redis).
# CACHE_PREFIX=swayy


# ===========================================================================
# QUEUE (Hintergrundaufgaben)
# ===========================================================================

# Treiber für die Job-Queue.
# "redis"    = empfohlen in Produktion (sehr schnell, Echtzeit-Verarbeitung)
# "database" = Fallback ohne Redis (Jobs in DB-Tabelle, leichte Verzögerung)
# "sync"     = sofortige Ausführung im selben Request (nur für lokale Tests!)
#
# Für Redis muss "php artisan queue:work" laufen (im Docker: "queue"-Service).
QUEUE_CONNECTION=redis


# ===========================================================================
# REDIS
# ===========================================================================

# PHP-Redis-Client. "phpredis" = C-Extension (schneller), "predis" = Pure-PHP.
# phpredis ist im offiziellen Docker-Image bereits installiert.
REDIS_CLIENT=phpredis

# Hostname des Redis-Servers.
# Docker: "redis" (Service-Name). Lokal: "127.0.0.1".
REDIS_HOST=127.0.0.1

# Redis-Passwort. Leer lassen, wenn Redis ohne Auth betrieben wird (Docker-Default).
# Für Produktionsserver mit öffentlichem Netzwerkzugang dringend setzen!
REDIS_PASSWORD=null

# Redis-Port. Standard: 6379.
REDIS_PORT=6379


# ===========================================================================
# E-MAIL / SMTP
# ===========================================================================
# Alle System-E-Mails (Buchungsbestätigung, Erinnerungen, Admin-Alerts) werden
# über diesen Mailer versendet.
#
# Empfohlene Anbieter (DSGVO-konform, DE-Server):
#   - SMTP2GO    smtp.smtp2go.com   Port 587   (günstig, zuverlässig)
#   - Mailjet    in-v3.mailjet.com  Port 587
#   - Postmark   smtp.postmarkapp.com Port 587  (sehr hohe Zustellrate)
#   - Strato     smtp.strato.de     Port 587
#
# Zum lokalen Testen: MAIL_MAILER=log   → E-Mails landen in storage/logs/laravel.log
# Oder Mailpit (Docker-Container): MAIL_HOST=mailpit MAIL_PORT=1025 MAIL_MAILER=smtp

# Treiber: "smtp" (Standard), "log" (nur Logs, kein Versand), "mailgun", "ses" etc.
MAIL_MAILER=smtp

# Verschlüsselung:
# "tls"   = STARTTLS, Port 587 (empfohlen)
# "smtps" = SSL direkt, Port 465
# Leer lassen für Port 25 (unverschlüsselt – bitte vermeiden!)
MAIL_SCHEME=tls

# Hostname des SMTP-Servers deines Anbieters.
MAIL_HOST=smtp.example.com

# SMTP-Port passend zur Verschlüsselung (587 für STARTTLS, 465 für SSL).
MAIL_PORT=587

# SMTP-Benutzername (oft die E-Mail-Adresse, manchmal eine API-Key-ID).
MAIL_USERNAME=

# SMTP-Passwort oder App-Passwort. Nie das reguläre E-Mail-Passwort nutzen –
# immer ein dediziertes SMTP-Passwort / App-Password verwenden!
MAIL_PASSWORD=

# Absenderadresse – muss im SMTP-Account verifiziert / erlaubt sein.
# Beispiel: "no-reply@meinrestaurant.de"
MAIL_FROM_ADDRESS="no-reply@example.com"

# Absendername, der im E-Mail-Client angezeigt wird.
MAIL_FROM_NAME="${APP_NAME}"


# ===========================================================================
# LOGGING
# ===========================================================================

# Log-Kanal. Optionen:
# "stack"  = mehrere Kanäle kombiniert (Standard)
# "single" = eine Datei: storage/logs/laravel.log
# "daily"  = tägliche Rotation (storage/logs/laravel-YYYY-MM-DD.log)
# "stderr" = Ausgabe auf STDERR (ideal für Docker / Systemd-Journal)
# "syslog" = an den System-Syslog-Daemon
LOG_CHANNEL=stack

# Welche Kanäle der "stack"-Kanal kombiniert (kommagetrennt).
# Beispiel: "daily,stderr" schreibt in Datei UND auf STDERR.
LOG_STACK=single

# Minimaler Log-Level. Alles ab diesem Level wird geschrieben.
# Reihenfolge (aufsteigend): debug → info → notice → warning → error → critical → alert → emergency
# Produktion: "warning" oder "error" (weniger Rauschen).
# Entwicklung: "debug" (alles).
LOG_LEVEL=warning

# Deprecation-Warnungen loggen? "null" = stumm (Standard). Nützlich beim Upgrade.
LOG_DEPRECATIONS_CHANNEL=null


# ===========================================================================
# SICHERHEIT
# ===========================================================================

# Bcrypt-Kosten für Passwort-Hashing. Je höher, desto sicherer und langsamer.
# 12 = guter Kompromiss (ca. 300 ms auf moderner Hardware).
# Nicht unter 10 setzen. Für sehr schnelle Server kann 13–14 verwendet werden.
BCRYPT_ROUNDS=12


# ===========================================================================
# ZAHLUNGSANBIETER & SMS
# ===========================================================================
# Stripe, PayPal und seven.io (SMS) werden PER TENANT im Admin-Backend
# konfiguriert – also über Einstellungen → Zahlungen / SMS in der jeweiligen
# Restaurant-/Salon-Verwaltung. Dort werden API-Keys, Webhook-Secrets und
# Absender-IDs pro Standort gespeichert.
#
# Es gibt hierfür KEINE globalen .env-Variablen.


# ===========================================================================
# DATEISPEICHER (optional)
# ===========================================================================

# Standard-Dateisystem. "local" = Dateien in storage/app/. Für Produktion mit
# mehreren Servern oder S3-Backups kann "s3" konfiguriert werden.
FILESYSTEM_DISK=local

# S3-kompatible Speicher (AWS S3, Hetzner Object Storage, MinIO, etc.)
# Nur nötig, wenn FILESYSTEM_DISK=s3 oder Backups zu S3 gewünscht.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=eu-central-1
# AWS_BUCKET=mein-swayy-bucket
# Für S3-kompatible Anbieter (nicht AWS): Endpunkt setzen
# AWS_ENDPOINT=https://s3.hetzner.com
# AWS_USE_PATH_STYLE_ENDPOINT=false


# ===========================================================================
# BROADCAST (Echtzeit-Events – nur bei separatem WebSocket-Server)
# ===========================================================================
# Swayy nutzt Server-Sent Events (SSE) für das Live-Board, keinen WebSocket-
# Server. Diese Variable kann auf "log" belassen werden.
BROADCAST_CONNECTION=log


# ===========================================================================
# VITE (Frontend-Build)
# ===========================================================================
# Nur für lokale Entwicklung mit "npm run dev" relevant.
VITE_APP_NAME="${APP_NAME}"
